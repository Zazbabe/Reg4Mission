@{
    ViewData["Title"] = "Välkommen";
    var justLoggedIn = Context.Request.Query["loggedIn"] == "1";
}

<div data-requires-auth="true" class="space-y-6">
    @if (justLoggedIn)
    {
        <div id="loginToast"
             class="fixed right-6 top-24 z-40 rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm font-medium text-emerald-800 shadow-lg transition-opacity duration-700">
            Du är nu inloggad
        </div>
    }

    <!-- Welcome text -->
    <div class="mb-2">
        <h1 class="text-3xl font-semibold text-slate-900">Välkommen till Resursportalen</h1>
        <p class="mt-2 text-slate-600">
            Du är nu inloggad och kan nu söka i registret och uppdatera din profil.
        </p>
    </div>

    <!-- Action cards -->
    <section class="grid gap-4 md:grid-cols-2">
        <!-- Search card -->
        <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md">
            <div class="flex items-start justify-between gap-4">
                <div>
                    <h2 class="text-xl font-semibold text-slate-900">Sök</h2>
                    <p class="mt-2 text-slate-600">
                        Sök bland kandidater i registret och filtrera efter kommun och avdelning.
                    </p>
                </div>
            </div>

            <div class="mt-6">
                <a class="inline-flex items-center justify-center rounded-lg bg-[var(--rp-accent)] px-4 py-2 font-semibold text-white hover:opacity-95"
                   asp-controller="Search" asp-action="Index">
                    Gå till sök
                </a>
            </div>
        </div>

        <!-- Profile card -->
        <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md">
            <div class="flex items-start justify-between gap-4">
                <div>
                    <h2 class="text-xl font-semibold text-slate-900">Min profil</h2>
                    <p class="mt-2 text-slate-600">
                        Se över dina uppgifter och uppdatera kontaktinformation, kommuner och valda områden.
                    </p>
                </div>
            </div>

            <div class="mt-6">
                <a class="inline-flex items-center justify-center rounded-lg border border-slate-300 bg-white px-4 py-2 font-semibold text-slate-700 hover:bg-slate-50"
                   asp-controller="Profile" asp-action="Index">
                    Gå till profil
                </a>
            </div>
        </div>
    </section>
</div>

@section Scripts {
    <script>
        (function () {
            const toast = document.getElementById("loginToast");
            if (!toast) return;

            // Remove loggedIn=1 from the url so the popup only shows once
            const url = new URL(window.location.href);
            if (url.searchParams.get("loggedIn") === "1") {
                url.searchParams.delete("loggedIn");
                window.history.replaceState({}, document.title, url.pathname + url.search + url.hash);
            }

            setTimeout(() => {
                toast.classList.add("opacity-0");

                setTimeout(() => {
                    toast.remove();
                }, 700);
            }, 2200);
        })();
    </script>
}