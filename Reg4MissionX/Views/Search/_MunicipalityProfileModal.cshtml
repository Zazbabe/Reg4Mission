@{
    var candidateId = (int)(ViewBag.CandidateId ?? 0);
}

<div class="modal fade" id="candidateModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Kandidatprofil (ID: @candidateId)</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Stäng"></button>
            </div>

            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-12 col-md-7">
                        <h6>Profil</h6>
                        <p class="text-muted">
                            Detta är en UI-placeholder. Här kommer faktisk kandidatinformation att visas senare.
                        </p>

                        <h6 class="mt-3">Intressen</h6>
                        <div class="text-muted">Plats för lista över intressen…</div>
                    </div>

                    <div class="col-12 col-md-5">
                        <div class="border rounded p-3 bg-light">
                            <h6 class="mb-2">Kontaktuppgifter</h6>

                            <!-- Always hidden until reveal -->
                            <div id="contactArea">
                                <p class="text-muted small mb-2">
                                    Kontaktuppgifter är dolda. Klicka för att visa
                                    (klicket kommer senare att loggas).
                                </p>

                                <form id="revealForm">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="candidateId" value="@candidateId" />

                                    <button class="btn btn-primary w-100" type="submit">
                                        Visa kontaktuppgifter
                                    </button>
                                </form>
                            </div>

                        </div>
                    </div>
                </div>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
                    Stäng
                </button>
            </div>

        </div>
    </div>
</div>