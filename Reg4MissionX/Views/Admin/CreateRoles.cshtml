@model Reg4MissionX.ViewModels.CreateRolesVm

@{
    ViewData["Title"] = "Skapa roller";
}

<div class="mx-auto max-w-3xl">
    <div class="mb-6">
        <h1 class="text-3xl font-semibold text-slate-900">Skapa roller</h1>
        <p class="mt-2 text-slate-600">Lägg till roller i Identity (UI + backend-stöd i ert Admin-flöde).</p>
    </div>

    <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
        <form asp-action="CreateRoles" method="post" class="space-y-4">
            @Html.AntiForgeryToken()

            <div>
                <label class="mb-1 block text-sm font-medium text-slate-700">Roller (komma-separerade)</label>

                <input asp-for="Roles"
                       class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2 outline-none focus:border-[var(--rp-accent)] focus:ring-4 focus:ring-[var(--rp-accent)]/20"
                       placeholder="Admin, SysAdmin, PrivateUser, TownshipUser" />

                <span asp-validation-for="Roles" class="mt-1 block text-sm text-rose-600"></span>

                <div class="mt-2 text-sm text-slate-500">
                    Exempel: <code class="rounded bg-slate-100 px-2 py-0.5 text-sm">Admin, SysAdmin, PrivateUser, TownshipUser</code>
                </div>
            </div>

            <div class="flex flex-wrap gap-3 pt-2">
                <button class="inline-flex items-center justify-center rounded-lg bg-[var(--rp-accent)] px-5 py-2 font-semibold text-white hover:opacity-95"
                        type="submit">
                    Skapa
                </button>

                <a class="inline-flex items-center justify-center rounded-lg border border-slate-300 bg-white px-5 py-2 font-semibold text-slate-700 hover:bg-slate-50"
                   asp-action="Index">
                    Tillbaka
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}