@model Reg4MissionX.ViewModels.CreateRolesVm
@{
    ViewData["Title"] = "Create Roles";
}

<div class="container py-4">
    <h2 class="mb-3">Create Roles</h2>

    <div class="card shadow-sm">
        <div class="card-body">
            <form asp-action="CreateRoles" method="post">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label class="form-label">Roles (comma-separated)</label>
                    <input asp-for="Roles" class="form-control" placeholder="Admin, SysAdmin, PrivateUser, TownshipUser" />
                    <span asp-validation-for="Roles" class="text-danger"></span>
                    <div class="form-text">Example: <code>Admin, SysAdmin, PrivateUser, TownshipUser</code></div>
                </div>

                <button class="btn btn-primary" type="submit">Create</button>
                <a class="btn btn-link" asp-action="Index">Back</a>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}