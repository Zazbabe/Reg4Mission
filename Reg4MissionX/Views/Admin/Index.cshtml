@{
    ViewData["Title"] = "Admin";
}

<div class="mx-auto max-w-5xl">
    <div class="mb-6">
        <h1 class="text-3xl font-semibold text-slate-900">Admin</h1>
        <p class="mt-2 text-slate-600">Administrera roller och behörigheter.</p>
    </div>

    @if (TempData["Success"] is string ok && !string.IsNullOrWhiteSpace(ok))
    {
        <div class="mb-4 rounded-lg border border-emerald-200 bg-emerald-50 px-4 py-3 text-emerald-900">
            @ok
        </div>
    }

    <div class="grid gap-4 lg:grid-cols-2">
        <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <h2 class="text-lg font-semibold text-slate-900">Skapa roller</h2>
            <p class="mt-2 text-slate-600">
                Skapa roller som <code class="rounded bg-slate-100 px-2 py-0.5 text-sm">Admin</code>,
                <code class="rounded bg-slate-100 px-2 py-0.5 text-sm">SysAdmin</code>,
                <code class="rounded bg-slate-100 px-2 py-0.5 text-sm">PrivateUser</code>,
                <code class="rounded bg-slate-100 px-2 py-0.5 text-sm">TownshipUser</code>.
            </p>

            <div class="mt-4">
                <a class="inline-flex items-center justify-center rounded-lg bg-[var(--rp-accent)] px-4 py-2 font-semibold text-white hover:opacity-95"
                   asp-controller="Admin" asp-action="CreateRoles">
                    Gå till “Skapa roller”
                </a>
            </div>
        </div>

        <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <h2 class="text-lg font-semibold text-slate-900">Hantera roller för en användare</h2>
            <p class="mt-2 text-slate-600">
                Klistra in ett <span class="font-semibold">userId</span> (GUID) från tabellen <code class="rounded bg-slate-100 px-2 py-0.5 text-sm">AspNetUsers</code>.
            </p>

            <form asp-controller="Admin" asp-action="GetRoles" method="get" class="mt-4 flex flex-col gap-3 sm:flex-row">
                <input class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2 outline-none focus:border-[var(--rp-accent)] focus:ring-4 focus:ring-[var(--rp-accent)]/20"
                       name="userId"
                       placeholder="UserId (GUID)"
                       autocomplete="off" />
                <button class="inline-flex items-center justify-center rounded-lg border border-slate-300 bg-white px-4 py-2 font-semibold text-slate-700 hover:bg-slate-50"
                        type="submit">
                    Öppna
                </button>
            </form>
        </div>
    </div>
</div>