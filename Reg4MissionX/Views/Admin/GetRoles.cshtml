@model Reg4MissionX.ViewModels.ManageUserRolesVm
@{
    ViewData["Title"] = "Manage User Roles";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="m-0">Manage User Roles</h2>
        <a class="btn btn-link" asp-action="Index">Back</a>
    </div>

    @if (TempData["Success"] is string ok && !string.IsNullOrWhiteSpace(ok))
    {
        <div class="alert alert-success">@ok</div>
    }

    <div class="card shadow-sm">
        <div class="card-body">
            <div class="mb-3">
                <div class="text-muted">User</div>
                <div class="fw-semibold">@Model.UserEmail</div>
                <div class="text-muted small">@Model.UserId</div>
            </div>

            <form asp-action="AddUserToRoles" method="post">
                @Html.AntiForgeryToken()

                <input type="hidden" asp-for="UserId" />
                <input type="hidden" asp-for="UserEmail" />

                <div class="mb-2 fw-semibold">Roles</div>

                @if (Model.AvailableRoles == null || !Model.AvailableRoles.Any())
                {
                    <div class="text-muted">No roles exist yet. Create roles first.</div>
                }
                else
                {
                    <div class="row">
                        @foreach (var role in Model.AvailableRoles)
                        {
                            var isChecked = Model.CurrentRoles.Contains(role);
                            <div class="col-12 col-md-6 col-lg-4 mb-2">
                                <div class="form-check">
                                    <input class="form-check-input"
                                           type="checkbox"
                                           name="CurrentRoles"
                                           value="@role"
                                           @(isChecked ? "checked" : "") />

                                    <label class="form-check-label">@role</label>
                                </div>
                            </div>
                        }
                    </div>
                }

                <span asp-validation-for="CurrentRoles" class="text-danger"></span>

                <div class="mt-3">
                    <button class="btn btn-primary" type="submit">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}