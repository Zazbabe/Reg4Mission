@model Reg4MissionX.ViewModels.HomeLoginVm

@{
    ViewData["Title"] = "Start";
}

<div class="grid gap-8 lg:grid-cols-12 lg:items-start">
    <!-- Left: Branding + info -->
    <section class="lg:col-span-7">
        <div class="mb-6">
            <img src="~/img/logo.png" alt="Resursportalen" class="h-32 w-auto" />
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
            <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
                <h2 class="mb-2 text-lg font-semibold text-slate-900">För kommuner</h2>
                <p class="text-slate-600">
                    Sök och kontakta uppdragstagare baserat på län, kommun och avdelning.
                </p>
            </div>

            <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
                <h2 class="mb-2 text-lg font-semibold text-slate-900">För privatpersoner</h2>
                <p class="text-slate-600">
                    Registrera dig för att kunna ta uppdrag i valda kommuner och avdelningar.
                </p>
            </div>
        </div>
    </section>

    <!-- Right: Login card -->
    <aside class="lg:col-span-5">
        <div id="login" class="lg:sticky lg:top-24">
            <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
                <h1 class="text-2xl font-semibold text-slate-900">Logga in</h1>
                <p class="mt-1 text-slate-600">För kommuner och registrerade användare</p>

                <form id="loginForm"
                      method="post"
                      asp-controller="Home"
                      asp-action="Login"
                      class="mt-5 space-y-4"
                      novalidate>

                    @Html.AntiForgeryToken()

                    <!-- keep return url -->
                    <input type="hidden" asp-for="ReturnUrl" />

                    <div asp-validation-summary="ModelOnly"
                         class="rounded-lg border border-rose-200 bg-rose-50 px-4 py-3 text-rose-900"
                         role="alert"></div>

                    <div>
                        <label asp-for="Email" class="mb-1 block text-sm font-medium text-slate-700">Mailadress</label>
                        <input asp-for="Email"
                               class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2 outline-none focus:border-[var(--rp-accent)] focus:ring-4 focus:ring-[var(--rp-accent)]/20"
                               autocomplete="username"
                               placeholder="namn@kommun.se" />
                        <span asp-validation-for="Email" class="mt-1 block text-sm text-rose-600"></span>
                    </div>

                    <div>
                        <label asp-for="Password" class="mb-1 block text-sm font-medium text-slate-700">Lösenord</label>
                        <input asp-for="Password"
                               class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2 outline-none focus:border-[var(--rp-accent)] focus:ring-4 focus:ring-[var(--rp-accent)]/20"
                               autocomplete="current-password" />
                        <span asp-validation-for="Password" class="mt-1 block text-sm text-rose-600"></span>
                    </div>

                    <label class="flex items-center gap-2 text-sm text-slate-700">
                        <input asp-for="RememberMe" class="h-4 w-4 accent-[var(--rp-accent)]" />
                        Kom ihåg mig
                    </label>

                    <button class="w-full rounded-lg bg-[var(--rp-accent)] px-4 py-2 font-semibold text-white hover:opacity-95"
                            type="submit">
                        Logga in
                    </button>

                    <a class="block w-full rounded-lg border border-slate-300 px-4 py-2 text-center font-medium text-slate-700 hover:bg-slate-50"
                       asp-controller="Account" asp-action="Register">
                        Registrera dig som privatperson
                    </a>

                    <div class="pt-1 text-sm">
                        <!-- Later: link to Identity forgot password -->
                        <a class="text-slate-500 underline decoration-slate-300 hover:text-slate-700"
                           href="/Identity/Account/ForgotPassword">
                            Glömt lösenord?
                        </a>
                    </div>
                </form>
            </div>

            <div class="mt-4 text-sm text-slate-500">
                Tips: använd arbetsmail. Inloggning är kopplad till mailadress.
            </div>
        </div>
    </aside>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}