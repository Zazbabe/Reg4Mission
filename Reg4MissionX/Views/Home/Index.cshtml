@{
    ViewData["Title"] = "Start";
}

<div class="grid gap-8 lg:grid-cols-12 lg:items-start">
    <!-- Left: Branding + info -->
    <section class="lg:col-span-7">
        <div class="mb-6">
            <img src="~/img/logo.png" alt="Resursportalen" class="h-32 w-auto" />
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
            <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
                <h2 class="mb-2 text-lg font-semibold text-slate-900">För kommuner</h2>
                <p class="text-slate-600">
                    Sök och kontakta uppdragstagare baserat på län, kommun och avdelning.
                </p>
            </div>

            <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
                <h2 class="mb-2 text-lg font-semibold text-slate-900">För privatpersoner</h2>
                <p class="text-slate-600">
                    Registrera dig för att kunna ta uppdrag i valda kommuner och avdelningar.
                </p>
            </div>
        </div>
    </section>

    <!-- Right: Login card -->
    <aside class="lg:col-span-5">
        <div id="login" class="lg:sticky lg:top-24">
            <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
                <h1 class="text-2xl font-semibold text-slate-900">Logga in</h1>
                <p class="mt-1 text-slate-600">För kommuner och registrerade användare</p>

                <form id="loginForm" method="post" action="/Account/Login" class="mt-5 space-y-4" novalidate>
                    <div>
                        <label class="mb-1 block text-sm font-medium text-slate-700">Mailadress</label>
                        <input class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2 outline-none focus:border-[var(--rp-accent)] focus:ring-4 focus:ring-[var(--rp-accent)]/20"
                               type="email"
                               name="Email"
                               autocomplete="username"
                               required
                               placeholder="namn@kommun.se" />
                        <p class="mt-1 hidden text-sm text-rose-600" data-val="email">Fyll i en giltig mailadress.</p>
                    </div>

                    <div>
                        <label class="mb-1 block text-sm font-medium text-slate-700">Lösenord</label>
                        <input class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2 outline-none focus:border-[var(--rp-accent)] focus:ring-4 focus:ring-[var(--rp-accent)]/20"
                               type="password"
                               name="Password"
                               autocomplete="current-password"
                               required />
                        <p class="mt-1 hidden text-sm text-rose-600" data-val="password">Fyll i lösenord.</p>
                    </div>

                    <button class="w-full rounded-lg bg-[var(--rp-accent)] px-4 py-2 font-semibold text-white hover:opacity-95"
                            type="submit">
                        Logga in
                    </button>

                    <a class="block w-full rounded-lg border border-slate-300 px-4 py-2 text-center font-medium text-slate-700 hover:bg-slate-50"
                       asp-controller="Account" asp-action="Register">
                        Registrera dig som privatperson
                    </a>

                    <div class="pt-1 text-sm">
                        <a class="text-slate-500 underline decoration-slate-300 hover:text-slate-700"
                           href="#">
                            Glömt lösenord?
                        </a>
                    </div>
                </form>
            </div>

            <div class="mt-4 text-sm text-slate-500">
                Tips: använd arbetsmail. Inloggning är kopplad till mailadress.
            </div>
        </div>
    </aside>
</div>

@section Scripts {
    <script>
        // Tailwind-friendly validation (no Bootstrap classes needed)
        (function () {
            const form = document.getElementById("loginForm");
            if (!form) return;

            const email = form.querySelector("input[name='Email']");
            const password = form.querySelector("input[name='Password']");
            const emailMsg = form.querySelector("[data-val='email']");
            const passMsg = form.querySelector("[data-val='password']");

            function show(el, shouldShow) {
                if (!el) return;
                el.classList.toggle("hidden", !shouldShow);
            }

            form.addEventListener("submit", function (e) {
                // Let our UI-only login in site.js handle redirect,
                // but still show basic validation messages.
                const emailOk = email && email.checkValidity();
                const passOk = password && password.checkValidity();

                show(emailMsg, !emailOk);
                show(passMsg, !passOk);

                if (!emailOk || !passOk) {
                    e.preventDefault();
                    e.stopPropagation();
                }
            });
        })();
    </script>
}