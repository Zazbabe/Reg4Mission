<!DOCTYPE html>
<html lang="sv">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Resursportalen</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Reg4MissionX.styles.css" asp-append-version="true" />
</head>

<body class="bg-light">
    <header>
        <nav class="navbar navbar-dark rp-navbar">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center gap-2" asp-controller="Home" asp-action="Index">
                    <img src="~/img/logo.png" alt="Resursportalen" class="rp-logo" />
                    <span class="fw-semibold rp-brand-text">Resursportalen</span>
                </a>

                <!-- Always visible hamburger (opens offcanvas) -->
                <button class="navbar-toggler d-inline-flex ms-auto rp-hamburger"
                        type="button"
                        data-bs-toggle="offcanvas"
                        data-bs-target="#mainOffcanvas"
                        aria-controls="mainOffcanvas"
                        aria-label="Meny">
                    <span class="navbar-toggler-icon"></span>
                </button>
            </div>
        </nav>

        <!-- Offcanvas menu (always used, all screen sizes) -->
        <div class="offcanvas offcanvas-end rp-offcanvas" tabindex="-1" id="mainOffcanvas" aria-labelledby="mainOffcanvasLabel">
            <div class="offcanvas-header">
                <div class="d-flex align-items-center gap-2">
                    <img src="~/img/logo.png" alt="Resursportalen" class="rp-logo" />
                    <h5 class="offcanvas-title mb-0" id="mainOffcanvasLabel">Resursportalen</h5>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Stäng"></button>
            </div>

            <div class="offcanvas-body">
                <!-- Meny -->
                <ul class="navbar-nav mb-3">

                    <li class="nav-item" id="navHome">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">Välkommen</a>
                    </li>

                    <!-- Utloggat-läge -->
                    <li class="nav-item" id="navRegister">
                        <a class="nav-link" asp-controller="Account" asp-action="Register" id="registerLink">Registrera</a>
                    </li>

                    <!-- Inloggat-läge (döljs av default, JS visar när "loggedIn" finns) -->
                    <li class="nav-item d-none" id="navDashboard">
                        <a class="nav-link" asp-controller="Dashboard" asp-action="Index">Översikt</a>
                    </li>

                    <li class="nav-item d-none" id="navSearch">
                        <a class="nav-link" asp-controller="Search" asp-action="Index">Sök</a>
                    </li>

                    <li class="nav-item d-none" id="navProfile">
                        <a class="nav-link" asp-controller="Profile" asp-action="Index">Profil</a>
                    </li>
                </ul>

                <hr class="my-3" />

                <!-- Auth actions -->
                <div class="d-grid gap-2">
                    <!-- Utloggat: Logga in hoppar till login-boxen på startsidan -->
                    <a class="btn btn-outline-primary" id="navLogin"
                       asp-controller="Home" asp-action="Index" asp-fragment="login">
                        Logga in
                    </a>

                    <!-- Inloggat: Logga ut (UI-only via JS) -->
                    <a class="btn btn-primary d-none" href="#" id="navLogout" data-action="logout">
                        Logga ut
                    </a>
                </div>

                <div class="mt-3 text-muted small">
                    <a class="link-light text-decoration-none" asp-controller="Home" asp-action="Privacy">Integritet</a>
                </div>
            </div>
        </div>
    </header>

    <!-- Page content -->
    <div class="container py-4">
        @if (TempData["Success"] is string success)
        {
            <div class="alert alert-success">@success</div>
        }
        @if (TempData["Error"] is string error)
        {
            <div class="alert alert-danger">@error</div>
        }

        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top bg-white">
        <div class="container py-3 text-muted small">
            &copy; 2026 - Resursportalen - <a asp-controller="Home" asp-action="Privacy">Integritet</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>