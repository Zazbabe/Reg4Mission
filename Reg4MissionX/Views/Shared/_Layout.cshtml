@using Microsoft.AspNetCore.Identity
<!DOCTYPE html>
<html lang="sv">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Resursportalen</title>

    <!-- Tailwind output (generated file) -->
    <link rel="stylesheet" href="~/css/app.css" asp-append-version="true" />

    <!-- Small project overrides (keep AFTER app.css so it can override) -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <link rel="stylesheet" href="~/Reg4MissionX.styles.css" asp-append-version="true" />
</head>

<body class="min-h-screen bg-slate-50 text-slate-900">
    <!-- Sticky top bar -->
    <header class="sticky top-0 z-50 border-b border-white/10 bg-[var(--rp-nav)]">
        <div class="mx-auto flex max-w-6xl items-center gap-3 px-4 py-3">
            <a id="brandLink" class="flex items-center gap-3" asp-controller="Home" asp-action="Index">
                <img src="~/img/logo.png" alt="Resursportalen" class="h-10 w-auto" />
                <span class="text-lg font-semibold tracking-wide text-white">Resursportalen</span>
            </a>

            <!-- Always visible hamburger button -->
            <!-- IMPORTANT: flex-col makes the 3 bars stack vertically -->
            <button id="menuBtn"
                    type="button"
                    class="ml-auto inline-flex h-10 w-10 flex-col items-center justify-center gap-1 rounded-lg border border-white/25 text-white hover:bg-white/10"
                    aria-label="Meny"
                    aria-controls="drawer"
                    aria-expanded="false">
                <span class="block h-[2px] w-5 bg-white"></span>
                <span class="block h-[2px] w-5 bg-white"></span>
                <span class="block h-[2px] w-5 bg-white"></span>
            </button>
        </div>
    </header>

    <!-- Drawer overlay (click to close) -->
    <div id="drawerOverlay" class="fixed inset-0 z-50 hidden bg-black/40"></div>

    <!-- Drawer (right side) -->
    <aside id="drawer"
           class="fixed right-0 top-0 z-50 h-full w-80 translate-x-full bg-[var(--rp-primary)] text-white shadow-lg transition-transform duration-200 ease-out">
        <div class="flex items-center gap-3 border-b border-white/10 px-4 py-4">
            <img src="~/img/logo.png" alt="Resursportalen" class="h-9 w-auto" />
            <div class="font-semibold">Resursportalen</div>

            <button id="drawerCloseBtn"
                    type="button"
                    class="ml-auto inline-flex h-9 w-9 items-center justify-center rounded-lg border border-white/15 hover:bg-white/10"
                    aria-label="Stäng meny">
                ✕
            </button>
        </div>

        <div class="px-4 py-4">
            <!-- Navigation -->
            <nav class="space-y-2">
                <a id="navHome"
                   class="block rounded-lg px-3 py-2 text-white/90 hover:bg-white/10"
                   asp-controller="Home" asp-action="Index">Välkommen</a>

                @if (User?.Identity?.IsAuthenticated == true)
                {
                    <a id="navDashboard"
                       class="block w-full rounded-lg px-3 py-2 text-white/90 hover:bg-white/10"
                       asp-controller="Dashboard" asp-action="Index">Översikt</a>

                    <a id="navSearch"
                       class="block w-full rounded-lg px-3 py-2 text-white/90 hover:bg-white/10"
                       asp-controller="Search" asp-action="Index">Sök</a>

                    <a id="navProfile"
                       class="block w-full rounded-lg px-3 py-2 text-white/90 hover:bg-white/10"
                       asp-controller="Profile" asp-action="Index">Profil</a>
                }
                else
                {
                    <!-- Register should go to Identity scaffold page -->
                    <a id="navRegister"
                       class="block rounded-lg px-3 py-2 text-white/90 hover:bg-white/10"
                       asp-area="Identity" asp-page="/Account/Register">Registrera</a>
                }
            </nav>

            <hr class="my-4 border-white/10" />

            <!-- Auth actions (REAL Identity login/logout) -->
            <div class="space-y-2">
                @if (User?.Identity?.IsAuthenticated == true)
                {
                    <form asp-area="Identity" asp-page="/Account/Logout" method="post">
                        <button type="submit"
                                class="w-full rounded-lg bg-[var(--rp-accent)] px-3 py-2 text-center font-semibold text-white hover:opacity-95">
                            Logga ut
                        </button>
                    </form>
                }
                else
                {
                    <a id="navLogin"
                       class="block w-full rounded-lg border border-white/20 px-3 py-2 text-center text-white hover:bg-white/10"
                       asp-area="Identity" asp-page="/Account/Login">
                        Logga in
                    </a>
                }
            </div>

            <div class="mt-4 text-sm text-white/70">
                <a class="underline decoration-white/30 hover:decoration-white"
                   asp-controller="Home" asp-action="Privacy">Integritet</a>
            </div>
        </div>
    </aside>

    <!-- Page content -->
    <main class="mx-auto max-w-6xl px-4 py-8">
        @if (TempData["Success"] is string success)
        {
            <div class="mb-4 rounded-lg border border-emerald-200 bg-emerald-50 px-4 py-3 text-emerald-900">@success</div>
        }
        @if (TempData["Error"] is string error)
        {
            <div class="mb-4 rounded-lg border border-rose-200 bg-rose-50 px-4 py-3 text-rose-900">@error</div>
        }

        @RenderBody()
    </main>

    <footer class="border-t border-slate-200 bg-white">
        <div class="mx-auto max-w-6xl px-4 py-4 text-sm text-slate-500">
            &copy; 2026 - Resursportalen - <a class="underline" asp-controller="Home" asp-action="Privacy">Integritet</a>
        </div>
    </footer>

    <!-- UI scripts -->
    <script src="~/js/site.js" asp-append-version="true"></script>



    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>