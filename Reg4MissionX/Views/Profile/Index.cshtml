@{
    ViewData["Title"] = "Min profil";
}

<div class="mx-auto max-w-5xl" data-requires-auth="true">
    <div class="mb-6">
        <h1 class="text-3xl font-semibold text-slate-900">Min profil</h1>
        <p class="mt-2 text-slate-600">UI-only: sparas inte i databasen än.</p>
    </div>

    <div class="grid gap-6 md:grid-cols-12">
        <!-- Left: Profile image -->
        <div class="md:col-span-4">
            <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
                <h2 class="text-lg font-semibold text-slate-900">Profilbild</h2>

                <div class="mt-4 overflow-hidden rounded-xl border border-slate-200 bg-slate-50">
                    <div class="aspect-square">
                        <img id="profilePreview"
                             alt="Profilbild"
                             class="hidden h-full w-full object-cover" />

                        <div id="profilePlaceholder"
                             class="flex h-full w-full items-center justify-center text-sm text-slate-500">
                            Ingen bild vald
                        </div>
                    </div>
                </div>

                <div class="mt-4">
                    <label class="mb-1 block text-sm font-medium text-slate-700">Ladda upp bild</label>
                    <input class="block w-full cursor-pointer rounded-lg border border-slate-300 bg-white text-sm text-slate-700 file:mr-3 file:rounded-md file:border-0 file:bg-slate-100 file:px-3 file:py-2 file:text-sm file:font-semibold file:text-slate-700 hover:file:bg-slate-200"
                           type="file"
                           id="profileImageInput"
                           accept="image/*" />
                    <div class="mt-2 text-sm text-slate-500">
                        Endast UI nu. Backend kommer senare spara bilden.
                    </div>
                </div>
            </div>
        </div>

        <!-- Right: Profile fields -->
        <div class="md:col-span-8">
            <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
                <h2 class="text-lg font-semibold text-slate-900">Uppgifter</h2>

                <div class="mt-4 grid gap-4 md:grid-cols-12">
                    <div class="md:col-span-6">
                        <label class="mb-1 block text-sm font-medium text-slate-700">Namn</label>
                        <input class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2 outline-none focus:border-[var(--rp-accent)] focus:ring-4 focus:ring-[var(--rp-accent)]/20"
                               placeholder="För- och efternamn" />
                    </div>

                    <div class="md:col-span-6">
                        <label class="mb-1 block text-sm font-medium text-slate-700">Mailadress</label>
                        <input class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2 outline-none focus:border-[var(--rp-accent)] focus:ring-4 focus:ring-[var(--rp-accent)]/20"
                               type="email"
                               placeholder="namn@exempel.se" />
                        <div class="mt-1 text-sm text-slate-500">
                            Om email används som inloggning kan den låsas senare - men UI-mässigt visar jag fältet nu.
                        </div>
                    </div>

                    <div class="md:col-span-6">
                        <label class="mb-1 block text-sm font-medium text-slate-700">Telefonnummer</label>
                        <input class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2 outline-none focus:border-[var(--rp-accent)] focus:ring-4 focus:ring-[var(--rp-accent)]/20"
                               placeholder="+46 70 123 45 67" />
                        <div class="mt-1 text-sm text-slate-500">
                            Viktigt att kunna uppdatera vid nummerbyte.
                        </div>
                    </div>

                    <div class="md:col-span-3">
                        <label class="mb-1 block text-sm font-medium text-slate-700">Ålder</label>
                        <input class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2 outline-none focus:border-[var(--rp-accent)] focus:ring-4 focus:ring-[var(--rp-accent)]/20"
                               type="number" min="0" max="120"
                               placeholder="t.ex. 32" />
                    </div>

                    <div class="md:col-span-3">
                        <label class="mb-1 block text-sm font-medium text-slate-700">Kön</label>
                        <select class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-slate-900 outline-none focus:border-[var(--rp-accent)] focus:ring-4 focus:ring-[var(--rp-accent)]/20">
                            <option value="">Välj…</option>
                            <option>Kvinna</option>
                            <option>Man</option>
                            <option>Icke-binär</option>
                            <option>Vill ej ange</option>
                        </select>
                    </div>

                    <div class="md:col-span-12">
                        <label class="mb-1 block text-sm font-medium text-slate-700">Intressen</label>
                        <textarea class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2 outline-none focus:border-[var(--rp-accent)] focus:ring-4 focus:ring-[var(--rp-accent)]/20"
                                  rows="3"
                                  placeholder="Skriv kort…"></textarea>
                    </div>
                </div>

                <div class="my-6 h-px bg-slate-200"></div>

                <div class="flex flex-wrap items-center gap-3">
                    <button type="button"
                            class="inline-flex cursor-not-allowed items-center justify-center rounded-lg bg-slate-200 px-5 py-2 font-semibold text-slate-500"
                            disabled>
                        Spara (kommer senare)
                    </button>

                    <span class="text-sm text-slate-500">UI-only</span>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // UI-only: Image preview for profile picture upload
        (function () {
            const input = document.getElementById("profileImageInput");
            const img = document.getElementById("profilePreview");
            const placeholder = document.getElementById("profilePlaceholder");

            if (!input || !img || !placeholder) return;

            input.addEventListener("change", () => {
                const file = input.files && input.files[0];
                if (!file) return;

                const url = URL.createObjectURL(file);
                img.src = url;

                img.classList.remove("hidden");
                placeholder.classList.add("hidden");
            });
        })();
    </script>
}