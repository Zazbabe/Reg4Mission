@{
    ViewData["Title"] = "Min profil";
}

<div class="mx-auto max-w-5xl" data-requires-auth="true">
    <div class="mb-6 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
        <div>
            <h1 class="text-3xl font-semibold text-slate-900">Min profil</h1>
            <p class="mt-2 text-slate-600">*/p>
        </div>

        <!-- Edit button -->
        <a asp-action="Edit"
           class="inline-flex items-center justify-center rounded-lg bg-[var(--rp-accent)] px-5 py-2 font-semibold text-white shadow-sm hover:opacity-95 focus:outline-none focus:ring-4 focus:ring-[var(--rp-accent)]/25">
            Redigera profil
        </a>
    </div>

    <div class="grid gap-6 md:grid-cols-12">
        <!-- Left: Profile image (view-only) -->
        <div class="md:col-span-4">
            <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
                <h2 class="text-lg font-semibold text-slate-900">Profilbild</h2>

                <div class="mt-4 overflow-hidden rounded-xl border border-slate-200 bg-slate-50">
                    <div class="aspect-square flex items-center justify-center">
                        <!-- UI-only: Use placeholder until backend stores an image -->
                        <div class="text-center">
                            <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-slate-200 text-slate-600">
                                <!-- simple avatar circle -->
                                <span class="text-lg font-semibold">ES</span>
                            </div>
                            <div class="mt-3 text-sm text-slate-500">Ingen bild uppladdad</div>
                        </div>
                    </div>
                </div>

                <div class="mt-4 text-sm text-slate-500">
                    Du kan ladda upp/ändra bild via <span class="font-medium text-slate-700">Redigera profil</span>.
                </div>
            </div>
        </div>

        <!-- Right: Profile fields (view-only) -->
        <div class="md:col-span-8">
            <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
                <h2 class="text-lg font-semibold text-slate-900">Uppgifter</h2>

                <!-- UI-only: Fake data for now. Later bind from model -->
                <div class="mt-4 grid gap-4 md:grid-cols-12">
                    <div class="md:col-span-6">
                        <div class="text-sm font-medium text-slate-700">Namn</div>
                        <div class="mt-1 rounded-lg border border-slate-200 bg-slate-50 px-3 py-2 text-slate-900">
                            Förnamn Efternamn
                        </div>
                    </div>

                    <div class="md:col-span-6">
                        <div class="text-sm font-medium text-slate-700">Mailadress</div>
                        <div class="mt-1 rounded-lg border border-slate-200 bg-slate-50 px-3 py-2 text-slate-900">
                            namn@exempel.se
                        </div>
                    </div>

                    <div class="md:col-span-6">
                        <div class="text-sm font-medium text-slate-700">Telefonnummer</div>
                        <div class="mt-1 rounded-lg border border-slate-200 bg-slate-50 px-3 py-2 text-slate-900">
                            +46 70 123 45 67
                        </div>
                    </div>

                    <div class="md:col-span-3">
                        <div class="text-sm font-medium text-slate-700">Ålder</div>
                        <div class="mt-1 rounded-lg border border-slate-200 bg-slate-50 px-3 py-2 text-slate-900">
                            32
                        </div>
                    </div>

                    <div class="md:col-span-3">
                        <div class="text-sm font-medium text-slate-700">Kön</div>
                        <div class="mt-1 rounded-lg border border-slate-200 bg-slate-50 px-3 py-2 text-slate-900">
                            Vill ej ange
                        </div>
                    </div>

                    <div class="md:col-span-12">
                        <div class="text-sm font-medium text-slate-700">Intressen</div>
                        <div class="mt-1 rounded-lg border border-slate-200 bg-slate-50 px-3 py-2 text-slate-900">
                            Skriv kort… *
                        </div>
                    </div>
                </div>

                <div class="my-6 h-px bg-slate-200"></div>

                <div class="flex flex-wrap items-center gap-3">
                    <span class="text-sm text-slate-500">*</span>
                </div>
            </div>
        </div>
    </div>
</div>