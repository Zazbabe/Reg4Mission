@{
    ViewData["Title"] = "Välkommen";
}

<div data-requires-auth="true">
    <div class="mb-6">
        <h1 class="text-3xl font-semibold text-slate-900">Välkommen!</h1>
        <p class="mt-2 text-slate-600">Du är nu i “inloggat läge” (UI-only).</p>
    </div>

    <div class="grid gap-4 md:grid-cols-2">
        <!-- Search card -->
        <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <div class="flex items-start justify-between gap-4">
                <div>
                    <h2 class="text-lg font-semibold text-slate-900">Sök</h2>
                    <p class="mt-1 text-slate-600">Sök i registret (kommer när backend är klar).</p>
                </div>
            </div>

            <div class="mt-5">
                <a class="inline-flex items-center justify-center rounded-lg bg-[var(--rp-accent)] px-4 py-2 font-semibold text-white hover:opacity-95"
                   asp-controller="Search" asp-action="Index">
                    Gå till Sök
                </a>
            </div>
        </div>

        <!-- Profile card -->
        <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <div class="flex items-start justify-between gap-4">
                <div>
                    <h2 class="text-lg font-semibold text-slate-900">Min profil</h2>
                    <p class="mt-1 text-slate-600">Uppdatera telefon, email och profilbild (UI-only).</p>
                </div>
            </div>

            <div class="mt-5">
                <a class="inline-flex items-center justify-center rounded-lg border border-slate-300 bg-white px-4 py-2 font-semibold text-slate-700 hover:bg-slate-50"
                   asp-controller="Profile" asp-action="Index">
                    Gå till Profil
                </a>
            </div>
        </div>
    </div>
</div>